{
  "expo": {
    "name": "ريبير درايفر",
    "slug": "RepairDriverApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "repairdriverapp",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#231a73"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.repairdriver.app",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "ar",
        "NSLocationWhenInUseUsageDescription": "نحتاج إذن الموقع لتحديد موقعك وإرساله للفني",
        "NSLocationAlwaysUsageDescription": "نحتاج إذن الموقع لتتبع موقع الفني",
        "NSCameraUsageDescription": "نحتاج إذن الكاميرا لالتقاط صور المشكلة",
        "NSPhotoLibraryUsageDescription": "نحتاج إذن الصور لإرفاق صور المشكلة"
      }
    },
    "android": {
      "package": "com.repairdriver.app",
      "adaptiveIcon": {
        "backgroundColor": "#231a73",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "نحتاج إذن الصور لإرفاق صور المشكلة",
          "cameraPermission": "نحتاج إذن الكاميرا لالتقاط صور المشكلة"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "نحتاج إذن الموقع لتتبع موقع الفني"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    },
    "locales": {
      "ar": "./src/i18n/ar.ts"
    }
  }
}
